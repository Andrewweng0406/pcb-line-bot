# APP
DEBUG=False
APP_NAME=PCB Quote Bot
APP_VERSION=2.0.0

# Web dashboard
SECRET_KEY=change-me-to-a-real-random-value
INVITE_CODE=change-me-to-a-shared-registration-code

# LINE Bot Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# OpenAI API (for text and image parsing)
OPENAI_API_KEY=your_openai_api_key

# Database - PostgreSQL (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/pcb_bot

# Redis Configuration (optional, for user memory persistence)
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379

# AWS S3 Configuration (optional, for file storage)
AWS_ENABLED=False
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# Public Base URL (for download links)
PUBLIC_BASE_URL=http://localhost:8000

# File Upload
MAX_UPLOAD_SIZE=10485760
